generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum HouseholdRole {
  owner
  member
}

enum CardAttribution {
  member
  shared
}

enum CardType {
  personal
  business
}

enum CardStatus {
  active
  frozen
  locked
  disconnected
  archived
}

enum DataSource {
  manual
  aggregator
}

enum SyncStatus {
  synced
  pending
  failed
  manual
}

enum PromoStatus {
  active
  expired
  cancelled
}

enum StatementSource {
  manual
  aggregator
  import
}

enum PaymentStatus {
  draft
  submitted
  processing
  settled
  failed
  returned
  cancelled
}

enum PaymentIntentStatus {
  draft
  processing
  submitted
  expired
}

enum RunwayItemSource {
  minimum
  promo_plan
  custom
}

enum AmountType {
  minimum
  statement
  current
  custom
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  memberships  HouseholdMembership[]
  preference   UserPreference?
  notifications Notification[]
  auditEvents  AuditEvent[]
  paymentIntents PaymentIntent[]
  payments     Payment[]
}

model UserPreference {
  userId          String @id
  displayCurrency String @default("USD")
  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Household {
  id        String             @id @default(cuid())
  name      String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  members   HouseholdMember[]
  memberships HouseholdMembership[]
  cards     CreditCard[]
  runwayItems RunwayItem[]
}

model HouseholdMember {
  id          String        @id @default(cuid())
  householdId String
  displayName String
  userId      String?
  role        HouseholdRole @default(member)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  ownedCards  CreditCard[]  @relation("CardOwner")

  @@index([householdId])
}

model HouseholdMembership {
  id          String        @id @default(cuid())
  householdId String
  userId      String
  role        HouseholdRole @default(member)
  createdAt   DateTime      @default(now())
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
}

model CreditCard {
  id                     String          @id @default(cuid())
  householdId            String
  ownerMemberId          String?
  attribution            CardAttribution @default(member)
  connectionId           String?
  institutionId          String?
  issuerKey              String?
  name                   String
  network                String
  lastFour               String
  cardType               CardType        @default(personal)
  currency               String          @default("USD")
  creditLimitMinor       BigInt
  currentBalanceMinor    BigInt
  statementBalanceMinor  BigInt          @default(0)
  minimumPaymentMinor    BigInt          @default(0)
  regularAprBps          Int             @default(0)
  paymentDueDay          Int?
  paymentDueDate         String?
  paymentDueTimeZone     String          @default("America/New_York")
  status                 CardStatus      @default(active)
  dataSource             DataSource      @default(manual)
  syncStatus             SyncStatus      @default(manual)
  lastSyncedAt           DateTime?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  household              Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  ownerMember            HouseholdMember? @relation("CardOwner", fields: [ownerMemberId], references: [id], onDelete: SetNull)
  promoPeriods           PromoPeriod[]
  statements             Statement[]
  payments               Payment[]
  paymentIntents         PaymentIntent[]
  runwayItems            RunwayItem[]

  @@index([householdId])
  @@index([ownerMemberId])
}

model PromoPeriod {
  id                   String      @id @default(cuid())
  cardId               String
  promoAprBps          Int         @default(0)
  regularAprBpsAfter   Int
  startsOn             String
  endsOn               String
  shelteredBalanceMinor BigInt
  status               PromoStatus @default(active)
  card                 CreditCard  @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, status])
}

model Statement {
  id                   String          @id @default(cuid())
  userId               String
  cardId               String
  currency             String
  periodStart          String
  periodEnd            String
  closingBalanceMinor  BigInt
  minimumPaymentMinor  BigInt
  paymentDueDate       String?
  source               StatementSource @default(manual)
  providerStatementId  String?
  documentUrl          String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  card                 CreditCard      @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([userId])
}

model FinancialAccount {
  id             String          @id @default(cuid())
  userId         String
  name           String
  currency       String          @default("USD")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  payments       Payment[]
  paymentIntents PaymentIntent[]
}

model PaymentIntent {
  id               String              @id @default(cuid())
  userId           String
  cardId           String?
  currency         String?
  amountType       AmountType?
  amountMinor      BigInt?
  accountId        String?
  scheduledFor     DateTime?
  status           PaymentIntentStatus @default(draft)
  expiresAt        DateTime
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  card             CreditCard?         @relation(fields: [cardId], references: [id], onDelete: SetNull)
  account          FinancialAccount?   @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId, status])
}

model RunwayItem {
  id                  String          @id @default(cuid())
  householdId         String
  cardId              String
  plannedPayDate      String
  contractualDueDate  String?
  amountMinor         BigInt
  currency            String          @default("USD")
  source              RunwayItemSource @default(minimum)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  household           Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  card                CreditCard      @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([householdId])
  @@index([cardId])
}

model Payment {
  id                String        @id @default(cuid())
  userId            String
  cardId            String
  accountId         String?
  amountMinor       BigInt
  currency          String
  status            PaymentStatus @default(draft)
  providerPaymentId String?
  idempotencyKey    String        @unique
  submittedAt       DateTime?
  settledAt         DateTime?
  failureReason     String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  card              CreditCard    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  account           FinancialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([cardId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  href      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

model AuditEvent {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
}
